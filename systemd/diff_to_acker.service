[Unit]
Description=Differential Drive to Ackermann Converter Node
After=network.target

[Service]
Type=simple
User=root
ExecStart=/bin/bash -c 'source /opt/ros/humble/setup.bash && \
          source /root/ros2_proj/hunter_ws/install/setup.bash && \
          ros2 run diff_to_acker converter_node'
Restart=always

[Install]
WantedBy=multi-user.target